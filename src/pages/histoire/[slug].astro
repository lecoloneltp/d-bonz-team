---
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const articlesEntries = Object.entries(
    import.meta.glob('../../content/histoire/*.md', { eager: true })
  );

  const allArticles = articlesEntries
    .map(([path, mod]: any) => {
      const slug = path.split('/').pop().replace('.md', '');

      return {
        slug,
        mod,
      };
    })
    .sort((a, b) => {
      const numA = parseInt(a.slug.match(/partie(\d+)/)?.[1] ?? "0");
      const numB = parseInt(b.slug.match(/partie(\d+)/)?.[1] ?? "0");

      return numA - numB;
    });

  return allArticles.map((item, index) => ({
    params: { slug: item.slug },
    props: {
      article: item.mod,
      next: allArticles[index + 1] ?? null,
    },
  }));
}

const { article, next } = Astro.props;
const Content = article.default;
---

<MainLayout title={article.frontmatter.title}>

  <header class="mb-12 max-w-3xl mx-auto">
    <h1 class="text-5xl font-bold leading-tight mb-4 tracking-tight">
      {article.frontmatter.title}
    </h1>

    <p class="text-xl text-zinc-300 leading-relaxed">
      {article.frontmatter.description}
    </p>
  </header>

  <div class="prose prose-invert max-w-3xl mx-auto lg:text-justify leading-relaxed">
    <Content />
  </div>

  <div class="mt-12 flex justify-end max-w-3xl mx-auto">
    {next && (
      <a
        href={`/histoire/${next.slug}`}
        class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-zinc-800 hover:bg-zinc-700 transition text-white"
      >
        Lire la suite →
      </a>
    )}
  </div>

</MainLayout>