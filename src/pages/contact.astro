---
import MainLayout from "../layouts/MainLayout.astro";

const facebookUrl = "https://www.facebook.com/DBonZTeam/";
const discordUrl = "https://discord.gg/YkRaUU97";
const steamUrl = "https://steamcommunity.com/groups/D-BONZ";
---

<MainLayout title="Contact">
  <main class="contact">
    <h1>Contact</h1>

    <p>Retrouvez-nous sur :</p>

    <div class="links">
      <a 
        href={facebookUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Facebook
      </a>

      <a 
        href={discordUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Discord
      </a>

        <a 
        href={steamUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Steam
      </a>

    </div>
  </main>
</MainLayout>

<style>
  .contact {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 1.2rem;
  }

  .links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  a {
    display: inline-block;
    padding: 0.8rem 1.8rem;
    border-radius: 10px;
    text-decoration: none;
    color: white;
    background: #5865F2;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  a:hover {
    transform: translateY(-3px);
    opacity: 0.9;
  }
</style>