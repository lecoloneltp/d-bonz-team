---
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import '../styles/global.css';

const { title = "Accueil" } = Astro.props;


//const canonicalURL = new URL(Astro.url.pathname, Astro.site);
//const { description } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>{title} - D-BonZ Team</title>
    <link rel="icon" type="image/svg+xml" href="/D-BonZ-Team-Logo.svg" />
    <link rel="icon" href="/D-BonZ-Team-Logo.ico" />
    <!--<link rel="canonical" href="{canonicalURL}" /> -->
    <meta name="viewport" content="width=device-width initial-scale=1" />
    <meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />
    <meta name="google-site-verification" content="9NvKEIfc_bk7YfcHmKnz8LSdcq4pZhwQ5r6LDhJ4i0c" />
    <!-- trouver comment rendre ça fonctionnel <meta name="description" content="{description}" /> -->
  </head>

  <body class="bg-zinc-900 text-zinc-100 min-h-screen">
    <Header />

    <main class="max-w-6xl mx-auto px-6 py-12">
      <slot />
    </main>

    <Footer />
  </body>
</html>